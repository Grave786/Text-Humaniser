# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Node / frontend tooling
frontend/node_modules/
npm-cache/

# Keep built frontend bundles tracked (HTML loads from frontend/dist)
!frontend/dist/
!frontend/dist/*.js

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE and editor settings
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
.env
